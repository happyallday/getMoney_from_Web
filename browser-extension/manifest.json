{
  "name": "WelfareHelper",
  "version": "0.1.0",
  "id": "welfare-helper-extension",
  "manifest_version": 3,
  "description": "合规福利获取助手 - 帮助用户更高效地获取各平台福利，支持表单自动填充和智能提醒",
  "permissions": [
    "storage",
    "notifications",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.jd.com/*",
    "*://*.taobao.com/*",
    "*://*.tmall.com/*",
    "*://*.pinduoduo.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.jd.com/*"],
      "js": ["content-scripts/ecommerce/jd.js", "content-scripts/content.js"],
      "css": ["content-scripts/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.taobao.com/*", "https://*.tmall.com/*"],
      "js": ["content-scripts/ecommerce/taobao.js", "content-scripts/content.js"],
      "css": ["content-scripts/styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.pinduoduo.com/*"],
      "js": ["content-scripts/ecommerce/pdd.js", "content-scripts/content.js"],
      "css": ["content-scripts/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "福利助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/*"],
      "matches": ["<all_urls>"]
    }
  ]
}